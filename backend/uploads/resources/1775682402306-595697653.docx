CREATE EXTENSION IF NOT EXISTS "uuid-ossp";‚Äé

CREATE TABLE utilisateur (‚Äé
‚Äé    id UUID PRIMARY KEY DEFAULT uuid_generate_v4(),‚Äé
‚Äé    nom VARCHAR(100) NOT NULL,‚Äé
‚Äé    prenom VARCHAR(100) NOT NULL,‚Äé
‚Äé    email VARCHAR(150) UNIQUE NOT NULL,‚Äé
‚Äé    mot_de_passe TEXT NOT NULL,‚Äé
‚Äé    role VARCHAR(50) DEFAULT 'admin' CHECK (role = 'admin'),‚Äé
‚Äé    etablissement VARCHAR(150),‚Äé
‚Äé    specialite VARCHAR(150),‚Äé
‚Äé    grade VARCHAR(100),‚Äé
‚Äé    bio TEXT,‚Äé
‚Äé    photo TEXT,‚Äé
‚Äé    date_creation TIMESTAMP DEFAULT CURRENT_TIMESTAMP,‚Äé
‚Äé    updated_at TIMESTAMP DEFAULT CURRENT_TIMESTAMP,‚Äé
‚Äé   ‚Äé);‚Äé

CREATE TABLE cours (‚Äé
‚Äé    id UUID PRIMARY KEY DEFAULT uuid_generate_v4(),‚Äé
‚Äé    id_utilisateur UUID NOT NULL,‚Äé
‚Äé    type VARCHAR(10) CHECK (type IN ('CM', 'TD', 'TP')),‚Äé
‚Äé    institution VARCHAR(150),‚Äé
‚Äé    annee VARCHAR(20) NOT NULL,‚Äé
‚Äé    intitule VARCHAR(200) NOT NULL,‚Äé
‚Äé    niveau VARCHAR(100),‚Äé
‚Äé    description TEXT,‚Äé
‚Äé    volume_horaire INT CHECK (volume_horaire >= 0),‚Äé
‚Äé    intervenants TEXT,‚Äé
‚Äé    evaluation TEXT,‚Äé
‚Äé    visible BOOLEAN DEFAULT TRUE,‚Äé
‚Äé    created_at TIMESTAMP DEFAULT CURRENT_TIMESTAMP,‚Äé
‚Äé    updated_at TIMESTAMP DEFAULT CURRENT_TIMESTAMP,‚Äé
‚Äé    FOREIGN KEY (id_utilisateur) REFERENCES utilisateur(id) ON DELETE CASCADE
‚Äé);‚Äé

CREATE TABLE ressource_pedagogique (‚Äé
‚Äé    id UUID PRIMARY KEY DEFAULT uuid_generate_v4(),‚Äé
‚Äé    id_cours UUID NOT NULL,‚Äé
‚Äé    titre VARCHAR(200) NOT NULL,‚Äé
‚Äé    fichier TEXT NOT NULL,‚Äé
‚Äé    nb_telechargements INT DEFAULT 0 CHECK (nb_telechargements >= 0),‚Äé
‚Äé    afficher_compteur BOOLEAN DEFAULT TRUE,‚Äé
‚Äé    visible BOOLEAN DEFAULT TRUE,‚Äé
‚Äé    created_at TIMESTAMP DEFAULT CURRENT_TIMESTAMP,‚Äé
‚Äé    updated_at TIMESTAMP DEFAULT CURRENT_TIMESTAMP,‚Äé
‚Äé    FOREIGN KEY (id_cours) REFERENCES cours(id) ON DELETE CASCADE
‚Äé);‚Äé

CREATE TABLE projet_recherche (‚Äé
‚Äé    id UUID PRIMARY KEY DEFAULT uuid_generate_v4(),‚Äé
‚Äé    id_utilisateur UUID NOT NULL,‚Äé
‚Äé    titre VARCHAR(200) NOT NULL,‚Äé
‚Äé    description TEXT,‚Äé
‚Äé    axe_recherche VARCHAR(200),‚Äé
‚Äé    date_debut DATE,‚Äé
‚Äé    date_fin DATE CHECK (date_fin >= date_debut),‚Äé
‚Äé    visible BOOLEAN DEFAULT TRUE,‚Äé
‚Äé    created_at TIMESTAMP DEFAULT CURRENT_TIMESTAMP,‚Äé
‚Äé    updated_at TIMESTAMP DEFAULT CURRENT_TIMESTAMP,‚Äé
‚Äé    FOREIGN KEY (id_utilisateur) REFERENCES utilisateur(id) ON DELETE CASCADE
‚Äé);‚Äé

CREATE TABLE blog_academique (‚Äé
‚Äé    id UUID PRIMARY KEY DEFAULT uuid_generate_v4(),‚Äé
‚Äé    id_utilisateur UUID NOT NULL,‚Äé
‚Äé    titre VARCHAR(200) NOT NULL,‚Äé
‚Äé    contenu TEXT NOT NULL,‚Äé
‚Äé    categorie VARCHAR(100),‚Äé
‚Äé    langue VARCHAR(5) CHECK (langue IN ('fr', 'en')),‚Äé
‚Äé    date_publication TIMESTAMP,‚Äé
‚Äé    visible BOOLEAN DEFAULT TRUE,‚Äé
‚Äé    created_at TIMESTAMP DEFAULT CURRENT_TIMESTAMP,‚Äé
‚Äé    updated_at TIMESTAMP DEFAULT CURRENT_TIMESTAMP,‚Äé
‚Äé    FOREIGN KEY (id_utilisateur) REFERENCES utilisateur(id) ON DELETE CASCADE
‚Äé);‚Äé

CREATE TABLE lien_externe (‚Äé
‚Äé    id UUID PRIMARY KEY DEFAULT uuid_generate_v4(),‚Äé
‚Äé    id_utilisateur UUID NOT NULL,‚Äé
‚Äé    type VARCHAR(50) CHECK (type IN ('github', 'linkedin', 'orcid', 'scholar')),‚Äé
‚Äé    url TEXT NOT NULL,‚Äé
‚Äé    FOREIGN KEY (id_utilisateur) REFERENCES utilisateur(id) ON DELETE CASCADE
‚Äé);‚Äé

CREATE TABLE parametres (‚Äé
‚Äé    id UUID PRIMARY KEY DEFAULT uuid_generate_v4(),‚Äé
‚Äé    id_utilisateur UUID UNIQUE NOT NULL,‚Äé
‚Äé    langue_principale VARCHAR(5) DEFAULT 'en' CHECK (langue_principale IN ('fr', 'en')),‚Äé
‚Äé    langue_secondaire VARCHAR(5) CHECK (langue_secondaire IN ('fr', 'en')),‚Äé
‚Äé    theme VARCHAR(10) DEFAULT 'light' CHECK (theme IN ('light', 'dark')),‚Äé
‚Äé    FOREIGN KEY (id_utilisateur) REFERENCES utilisateur(id) ON DELETE CASCADE
‚Äé);‚Äé

CREATE TABLE statistique (‚Äé
‚Äé    id UUID PRIMARY KEY DEFAULT uuid_generate_v4(),‚Äé
‚Äé    id_utilisateur UUID UNIQUE NOT NULL,‚Äé
‚Äé    nb_cours INT DEFAULT 0,‚Äé
‚Äé    nb_cm INT DEFAULT 0,‚Äé
‚Äé    nb_td INT DEFAULT 0,‚Äé
‚Äé    nb_tp INT DEFAULT 0,‚Äé
‚Äé    nb_ressources INT DEFAULT 0,‚Äé
‚Äé    nb_telechargements INT DEFAULT 0,‚Äé
‚Äé    nb_projets_recherche INT DEFAULT 0,‚Äé
‚Äé    nb_articles_blog INT DEFAULT 0,‚Äé
‚Äé    FOREIGN KEY (id_utilisateur) REFERENCES utilisateur(id) ON DELETE CASCADE
‚Äé);‚Äé

CREATE INDEX idx_cours_user ON cours(id_utilisateur);‚Äé
CREATE INDEX idx_projet_user ON projet_recherche(id_utilisateur);‚Äé
CREATE INDEX idx_blog_user ON blog_academique(id_utilisateur);‚Äé
CREATE INDEX idx_ressource_cours ON ressource_pedagogique(id_cours);‚Äé

CREATE OR REPLACE FUNCTION update_timestamp()‚Äé
RETURNS TRIGGER AS $$‚Äé
BEGIN
‚Äé    NEW.updated_at = CURRENT_TIMESTAMP;‚Äé
‚Äé    RETURN NEW;‚Äé
END;‚Äé
‚Äé$$ LANGUAGE plpgsql;‚Äé

CREATE TRIGGER trg_user BEFORE UPDATE ON utilisateur
FOR EACH ROW EXECUTE FUNCTION update_timestamp();‚Äé

CREATE TRIGGER trg_cours BEFORE UPDATE ON cours
FOR EACH ROW EXECUTE FUNCTION update_timestamp();‚Äé

CREATE TRIGGER trg_blog BEFORE UPDATE ON blog_academique
FOR EACH ROW EXECUTE FUNCTION update_timestamp();‚Äé